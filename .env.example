# FinAI configuration template.
#
# Copy this file to .env and fill in your own values:
#     cp .env.example .env
#
# .env is gitignored, so your secrets are never committed. Real shell
# environment variables override .env, so CI can export these instead.
# Every value is optional until a code path that needs it runs, so the
# offline test suite passes with this file empty.

# ---------------------------------------------------------------------------
# SEC EDGAR  (Task 1: 10-K retrieval)
# ---------------------------------------------------------------------------
# SEC requires a descriptive User-Agent identifying you: "Name email".
SEC_USER_AGENT="FinAI Research your-email@example.com"

# ---------------------------------------------------------------------------
# Financial Modeling Prep  (Task 4: structured financials)
# Free key: https://financialmodelingprep.com/developer/docs
# ---------------------------------------------------------------------------
FMP_API_KEY=

# ---------------------------------------------------------------------------
# FinnHub  (Task 5: company news)
# Free key: https://finnhub.io/
# ---------------------------------------------------------------------------
FINNHUB_API_KEY=

# ---------------------------------------------------------------------------
# Reddit / PRAW  (Task 6: social posts)
# Register an app: https://www.reddit.com/prefs/apps  (type: "script")
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT="finai-research/0.1 by u/your_reddit_username"

# ---------------------------------------------------------------------------
# LLM backbone  (the agents, Tasks 10-17)
# ---------------------------------------------------------------------------
# Two kinds of backend, chosen by LLM_BACKEND:
#   - "anthropic"           -> the hosted Anthropic API (Claude).
#   - OpenAI-compatible      -> accepted values: local, openai, deepseek,
#                              vllm, openai-compatible. All route through
#                              the OpenAI SDK pointed at LOCAL_MODEL_BASE_URL,
#                              so the endpoint can be local OR a remote API.
#
# The agents use tool calling, so the model must support OpenAI-style
# function/tool calling (e.g. claude-*, gpt-4o, deepseek-chat, most
# instruct models on vLLM; pure reasoning models like deepseek-reasoner
# may not).
LLM_BACKEND=anthropic

# Model id. Defaults: claude-opus-4-8 (anthropic) / llama3.1 (otherwise).
LLM_MODEL=claude-opus-4-8

# --- when LLM_BACKEND=anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI-compatible endpoint (local / openai / deepseek / vllm) ---
# These configure the OpenAI-compatible endpoint. Despite the "LOCAL_"
# name they can point at a remote API. Default is a local vLLM on :8000.
LOCAL_MODEL_BASE_URL=http://localhost:8000/v1
LOCAL_MODEL_API_KEY=vllm

# Examples -- copy values into the four lines above
# (LLM_BACKEND / LLM_MODEL / LOCAL_MODEL_BASE_URL / LOCAL_MODEL_API_KEY):
#
#   OpenAI:
#     LLM_BACKEND=openai
#     LLM_MODEL=gpt-4o
#     LOCAL_MODEL_BASE_URL=https://api.openai.com/v1
#     LOCAL_MODEL_API_KEY=sk-...
#
#   DeepSeek:
#     LLM_BACKEND=deepseek
#     LLM_MODEL=deepseek-chat
#     LOCAL_MODEL_BASE_URL=https://api.deepseek.com/v1
#     LOCAL_MODEL_API_KEY=sk-...
#
#   Local vLLM serving Qwen  (start: vllm serve Qwen/Qwen2.5-7B-Instruct):
#     LLM_BACKEND=vllm
#     LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#     LOCAL_MODEL_BASE_URL=http://localhost:8000/v1
#     LOCAL_MODEL_API_KEY=vllm

# ---------------------------------------------------------------------------
# Run artifacts  (agent transcripts + reports)
# ---------------------------------------------------------------------------
# Base directory for per-run output; each run writes to
# <RUNS_DIR>/<TICKER>_<timestamp>/ (transcript.json, transcript.md,
# report.json). Gitignored. Defaults to 'runs'.
RUNS_DIR=runs
